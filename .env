# Discord
DISCORD_TOKEN=your_discord_bot_token
VERIFY_CHANNEL=verify
DISCORD_GUILD_ID=1400787114333044887
VERIFY_CHANNEL_ID=0

# X OAuth2
X_CLIENT_ID=your_x_client_id
X_CLIENT_SECRET=your_x_client_secret
X_REDIRECT_URI=http://localhost:8000/x/callback
X_SCOPES=users.read tweet.read

# Callback server
OAUTH_HOST=0.0.0.0
OAUTH_PORT=8000
PORT=8000

# Database
DATABASE_URL=
DB_FILE=bot_database.db

# Shared link signing secret
LINK_SECRET=change-me-to-a-long-random-secret

# OCR tuning
OCR_CONCURRENCY=1
OCR_CANVAS_SIZE=1920
OCR_BEAM_WIDTH=5
OCR_BATCH_SIZE=1
OCR_WORKERS=0
